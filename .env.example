# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Resend Email Service
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# From Email - Email người gửi (phải là email đã đăng ký Resend hoặc domain đã verify)
# Nếu dùng free plan, dùng: onboarding@resend.dev
# Nếu đã verify domain, dùng: noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Contact Email - Email nhận thông tin liên hệ từ form
